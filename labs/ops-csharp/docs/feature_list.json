{
  "$schema": "harness/feature-list/v1",
  "description": "OPS Lab C# — harness controls state (pass-state gating).",
  "rules": {
    "wip_limit": 1,
    "allowed_states": ["not_started", "active", "blocked", "passing"],
    "gating": "Only harness may set passing after verification exits 0"
  },
  "features": [
    {
      "id": "F01",
      "behavior": "HealthStatus.GetStatus() returns \"ok\" (baseline API health)",
      "verification": "dotnet test --filter FullyQualifiedName~F01_health_returns_ok --verbosity quiet",
      "state": "passing",
      "evidence": {
        "commit": "",
        "verified_at": "",
        "notes": "Seed example — Project 01 baseline health check"
      }
    },
    {
      "id": "F02",
      "behavior": "Repo root contains AGENTS.md (agent-readable workspace)",
      "verification": "dotnet test --filter FullyQualifiedName~F02_workspace_has_agents_md --verbosity quiet",
      "state": "passing",
      "evidence": {
        "commit": "",
        "verified_at": "",
        "notes": "Project 02 — workspace harness files present"
      }
    },
    {
      "id": "F03",
      "behavior": "CI workflow runs dotnet test for ops-csharp lab on push",
      "verification": "dotnet test labs/ops-csharp --verbosity quiet",
      "state": "active",
      "evidence": {
        "commit": "",
        "verified_at": "",
        "notes": "OPS deliverable — wire into GitHub Actions (WIP=1)"
      }
    }
  ]
}
